{
  "name": "payroll-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:keepalive": "bash scripts/dev-keepalive.sh start",
    "dev:auto": "bash scripts/dev-keepalive.sh start-auto",
    "dev:auto:status": "bash scripts/dev-keepalive.sh status-auto",
    "dev:health": "bash scripts/dev-keepalive.sh health",
    "dev:prewarm": "bash scripts/dev-keepalive.sh prewarm",
    "dev:stop": "bash scripts/dev-keepalive.sh stop",
    "dev:logs": "bash scripts/dev-keepalive.sh logs",
    "build": "next build",
    "postinstall": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "start": "prisma migrate deploy && next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "data:purge-seeded-test": "tsx scripts/purge-seeded-test-data.ts --execute"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.99.0",
