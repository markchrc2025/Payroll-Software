  CREATE
  READ
  UPDATE
  DELETE
  APPROVE
  EXPORT
}

enum SubscriptionTier {
  STARTER
  GROWTH
  PRO
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELLED
}

enum EmploymentStatus {
  PROBATIONARY
  REGULAR
  CONTRACTUAL
  PROJECT_BASED
  RESIGNED
  TERMINATED
  RETIRED
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CASUAL
}

enum PayFrequency {
  DAILY
  WEEKLY
  BI_WEEKLY
  SEMI_MONTHLY
  MONTHLY
}

enum SalaryType {
  DAILY
  WEEKLY
  MONTHLY
}

