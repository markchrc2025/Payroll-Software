  SUPER_ADMIN
  TENANT_USER
}

enum PermissionModule {
  EMPLOYEES
  DEPARTMENTS
  BRANCHES
  PAYROLL
  TIMESHEETS
  LEAVES
  REPORTS
  COMPLIANCE
  SETTINGS
  ROLES
  INCIDENTS
  MOVEMENTS
  DOCUMENTS
  AUDIT
}

