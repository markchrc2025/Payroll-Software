/// Audit log target kinds — kept open via String for forward-compat.
enum AuditAction {
  CREATE
  UPDATE
  DELETE
  READ
  APPROVE
  REJECT
  EXPORT
  LOGIN
  LOGOUT
  IMPERSONATE
}

enum ConsentType {
  BIOMETRIC_SELFIE
  GEOLOCATION
  KIOSK_PHOTO
  DATA_PROCESSING
  MARKETING
}

enum AiTouchpoint {
  DOC_EXTRACTION
  HR_CHAT
  PAYSLIP_QA
  COMPLIANCE_HELPER
  RESUME_PARSE
  ANOMALY_FLAGGING
}

/// Statutory rule category (Phase D1). Each row in `StatutoryRule` carries a
/// polymorphic JSON `payload` whose shape is validated at the application
/// layer via zod (`src/lib/statutory/types.ts`).
enum StatutoryCategory {
  SSS_SCHEDULE
  PHILHEALTH_SCHEDULE
  PAGIBIG_SCHEDULE
  BIR_WITHHOLDING_TABLE
  DE_MINIMIS_CEILING
  MINIMUM_WAGE_RATE
}

// ---------------------------------------------------------------------------
// PAYROLL DOMAIN (Phase D2)
// ---------------------------------------------------------------------------

/// Broad family of a pay component. Drives default sign (earning vs deduction)
/// and the default taxability override matrix in the engine.
enum PayComponentKind {
  ALLOWANCE
  BONUS
  COMMISSION
  OTHER_EARNING
  REIMBURSEMENT
  DEDUCTION
}

/// Tax treatment of a pay component.
///   • TAXABLE — added to taxable gross.
///   • NON_TAXABLE — added to gross but not to BIR taxable base.
///   • DE_MINIMIS — subject to the RR 29-2025 ceiling (excess is taxable);
///                  `deMinimisCode` MUST be set and must reference a code from
///                  the active `DE_MINIMIS_CEILING` payload.
///   • STATUTORY_EXEMPT — mandatory contributions / 13th-month residual; engine
///                        emits these, not the catalog.
enum PayComponentTaxability {
  TAXABLE
  NON_TAXABLE
  DE_MINIMIS
  STATUTORY_EXEMPT
}

/// Loan source. Drives default ledger account and government-loan amortization
/// rules.
enum LoanType {
  SSS
  PAGIBIG
  CASH_ADVANCE
  COMPANY
}

enum LoanStatus {
  ACTIVE
  PAID
  CANCELLED
  ON_HOLD
}

/// Payroll run lifecycle. DRAFT → FINALIZED is a one-way transition (writes
/// AuditLog + decrements loan balances). CANCELLED is reserved for runs that
/// were created in error before finalize.
enum PayrollBookStatus {
  DRAFT
  PROCESSING
  FINALIZED
  CANCELLED
}

enum PayrollRunType {
  REGULAR
  OFF_CYCLE
  FINAL_PAY
  YEAR_END
}

enum AdjustmentKind {
  ADDITION
  DEDUCTION
}

/// Reason an employee's employment was terminated.  Drives DOLE separation-pay
/// formula and BIR taxability rules for the FINAL_PAY run.
enum SeparationReason {
  /// Voluntary resignation — no statutory separation pay; any gratuity is taxable.
  RESIGNATION
  /// Mutually agreed separation — no statutory separation pay.
  MUTUAL_AGREEMENT
  /// End of project / fixed-term contract — no statutory separation pay.
  END_OF_CONTRACT
  /// Art. 298 RA 10361 — 1 month per year (or fraction ≥ 6 mo) of service.
  REDUNDANCY
  /// Art. 298 — 0.5 month per year (min 1 month); exempt from WHT.
  RETRENCHMENT
  /// Art. 298 — 1 month per year when not due to serious losses; exempt from WHT.
  CLOSURE_OF_BUSINESS
  /// Art. 299 — disease not curable within 6 months; 1 month per year; exempt.
  DISEASE
  /// Art. 297 — dismissal for just cause; no separation pay by law.
  JUST_CAUSE
}

// =============================================================================
// DTR / TIMESHEET ENUMS (Phase J)
// =============================================================================

enum ShiftType {
  FIXED
  FLEXIBLE
}

enum BreakPolicy {
  /// System auto-deducts breakMinutes from the total span (firstIN → lastOUT).
  /// Employee does NOT clock out for lunch.
  FIXED_DEDUCTION
  /// System sums only actual paired IN-OUT intervals.
  /// Employee must clock out before lunch and clock back in after.
  TRACK_ACTUAL
}

enum DTRStatus {
  PENDING
  APPROVED
  REJECTED
}

/// Reason an employee or supervisor provides when writing a manual time override.
enum DTRManualReasonCode {
  FORGOT_CLOCK_IN
  FORGOT_CLOCK_OUT
  GPS_FAILURE
  KIOSK_OFFLINE
  SYSTEM_ERROR
  SCHEDULE_CHANGE
  /// Requires a non-empty `manualNotes` value at the application layer.
  OTHER
}

/// Multi-step lifecycle of a period-level DTR submission.
enum DTRSubmissionStatus {
  /// Employee has submitted; awaiting supervisor review.
  SUBMITTED
  /// Supervisor has reviewed and approved; awaiting manager sign-off.
  SUPERVISOR_APPROVED
  /// Manager has given final approval; eligible for payroll engine.
  MANAGER_APPROVED
  /// Returned by supervisor (back to employee) or manager (back to supervisor).
  RETURNED
}

enum DTRDayStatus {
  PRESENT
  ABSENT
  PAID_LEAVE
  UNPAID_LEAVE
  HOLIDAY
  REST_DAY
}

// =============================================================================
// ATTENDANCE ENUMS (Phase Y)
// =============================================================================

enum PunchType {
  IN
  OUT
}

enum PunchSource {
  KIOSK
  ESS
  IMPORT
  MANUAL
}

// =============================================================================
// HOLIDAY CALENDAR ENUMS (Phase AD)
// =============================================================================

/// DOLE holiday category — drives the payroll multiplier applied to the day.
enum HolidayCategory {
  /// Regular Holiday (Art. 94 Labor Code) — 200% pay if worked, 100% if not worked.
  LEGAL
  /// Special Non-Working Day (nationwide proclamation) — 130% if worked, no pay if not.
  SPECIAL_NON_WORKING
  /// Special One-Time Holiday (presidential proclamation) — 130% if worked.
  SPECIAL_ONE_TIME
  /// City/province/region-scoped holiday — 130% if worked, applies to matching branches only.
  AREA_SPECIFIC
}

enum HolidayScope {
  /// Applies to all employees regardless of branch.
  COMPANY_WIDE
  /// Applies only to employees in the listed branch IDs.
  BRANCH_SPECIFIC
}

enum PremiumMultiplierKey {
  OT
  NSD
  REST_DAY
  REST_DAY_OT
  SPECIAL_HOLIDAY
  SPECIAL_HOLIDAY_OT
  SPECIAL_HOLIDAY_REST_DAY
  SPECIAL_HOLIDAY_REST_DAY_OT
  REGULAR_HOLIDAY
  REGULAR_HOLIDAY_OT
  REGULAR_HOLIDAY_REST_DAY
  REGULAR_HOLIDAY_REST_DAY_OT
  DOUBLE_HOLIDAY
  DOUBLE_HOLIDAY_OT
  DOUBLE_HOLIDAY_REST_DAY
  DOUBLE_HOLIDAY_REST_DAY_OT
  HAZARD
  NO_WORK_REGULAR_HOLIDAY
}

// =============================================================================
// TENANT (SaaS customer)
// =============================================================================

model Tenant {
  id        String  @id @default(cuid())
  name      String
  tradeName String?
  subdomain String? @unique
  industry  String?

  // Encrypted at app layer
  tinNumber        String? @unique
  sssNumber        String?
  philhealthNumber String?
  pagibigNumber    String?

  address      String?
  city         String?
  province     String?
  zipCode      String?
  country      String  @default("Philippines")
  contactEmail String?
  contactPhone String?
  logoUrl      String?

  // Subscription
  subscriptionTier   SubscriptionTier   @default(STARTER)
  subscriptionStatus SubscriptionStatus @default(TRIALING)
  trialEndsAt        DateTime?
  billingEmail       String?

  /// Per-tenant feature toggles (e.g. {"ai_assistant": true, "ats": false}).
  featureFlags Json @default("{}")

  // Payroll defaults (§9 of blueprint)
  payrollCycle           PayFrequency         @default(SEMI_MONTHLY)
  /// For Semi-Monthly/Monthly: day of month (1–28). For Weekly/Bi-Weekly: ISO weekday (1=Mon … 7=Sun).
  payDay1                Int?
  /// Second pay day — only used for Semi-Monthly (e.g. 1 & 15 → payDay1=1, payDay2=15).
  payDay2                Int?
  workingDaysDenominator Int                  @default(261)
  statutoryCutoffRule    StatutoryCutoffRule  @default(SECOND_CUTOFF)
  thirteenthMonthBasis   ThirteenthMonthBasis @default(STRICT_DOLE)
  defaultDtrApproverId   String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  users                 User[]
  roles                 Role[]
  departments           Department[]
  branches              Branch[]
  workLocations         WorkLocation[]
  positions             Position[]
  employees             Employee[]
  statutoryIds          StatutoryId[]
  employeeSalaries      EmployeeSalary[]
  employeeMovements     EmployeeMovement[]
  incidentReports       IncidentReport[]
  assets               Asset[]
  assetAssignments     AssetAssignment[]
  employeeDocuments     EmployeeDocument[]
  geofences             Geofence[]
  kiosks                Kiosk[]
  leaveTypes            LeaveType[]
  leaveTransactions     LeaveTransaction[]
  dtrApprovalConfig     DTRApprovalConfig?
  auditLogs             AuditLog[]
  consentRecords        ConsentRecord[]
  aiUsage               AiUsage[]
  statutoryRules        StatutoryRule[]
  payComponents         PayComponent[]
  employeePayComponents EmployeePayComponent[]
  periodInputs          PeriodInput[]
  loans                 Loan[]
  payrollBooks          PayrollBook[]
  payrollSheets         PayrollSheet[]
  payrollAdjustments    PayrollAdjustment[]
  shiftSchedules        ShiftSchedule[]
  shiftAssignments      EmployeeShiftAssignment[]
  dtrRecords            DTRRecord[]
  attendanceLogs        AttendanceLog[]
  expenseClaims         ExpenseClaim[]
  essSessions           EssSession[]
  otApplications        OTApplication[]
  undertimeRequests     UndertimeRequest[]
  profileUpdateRequests ProfileUpdateRequest[]
  dtrSubmissions        DTRSubmission[]
  dtrAuditLogs          DTRAuditLog[]

  defaultDtrApprover Employee? @relation("TenantDefaultDtrApprover", fields: [defaultDtrApproverId], references: [id])

  jobPostings    JobPosting[]
  applicants     Applicant[]
  applicantNotes ApplicantNote[]
  holidays       Holiday[]
  premiumRateConfigs PremiumRateConfig[]

  @@index([deletedAt])
}

// =============================================================================
// USERS & RBAC
// =============================================================================

model User {
  id           String  @id @default(cuid())
  tenantId     String? // NULL for SUPER_ADMIN users
  email        String
  passwordHash String
  firstName    String
  lastName     String

  systemRole SystemRole @default(TENANT_USER)
  roleId     String?

  essPinHash String?

  isActive    Boolean   @default(true)
  lastLoginAt DateTime?

  twoFactorEnabled Boolean @default(false)
  twoFactorSecret  String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant       Tenant?   @relation(fields: [tenantId], references: [id])
  assignedRole Role?     @relation(fields: [roleId], references: [id])
  employee     Employee?
  approvedExpenseClaims ExpenseClaim[] @relation("ExpenseClaimApprover")

  createdJobPostings    JobPosting[]
  assignedApplicants    Applicant[]       @relation("ApplicantAssignedTo")
  applicantNotes        ApplicantNote[]
  passwordResetTokens   PasswordResetToken[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([roleId])
  @@index([deletedAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique // SHA-256 hex of the raw token
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Role {
  id          String  @id @default(cuid())
  tenantId    String
  name        String
  description String?
  isSystem    Boolean @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant      Tenant           @relation(fields: [tenantId], references: [id])
  permissions RolePermission[]
  users       User[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([deletedAt])
}

model Permission {
  id     String           @id @default(cuid())
  module PermissionModule
  action PermissionAction
  label  String

  roles RolePermission[]

  @@unique([module, action])
}

model RolePermission {
  roleId           String
  permissionId     String
  departmentScoped Boolean @default(false)

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

// =============================================================================
// ORG STRUCTURE
// =============================================================================

model WorkLocation {
  id       String  @id @default(cuid())
  tenantId String
  name     String
  /// PSGC / DOLE region code — drives minimum-wage lookup (e.g. "NCR", "CAR", "07").
  region   String
  address  String?
  city     String?
  province String?
  zipCode  String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  branches Branch[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([deletedAt])
}

model Department {
  id          String  @id @default(cuid())
  tenantId    String
  name        String
  description String?
  managerId   String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  employees Employee[]
  jobPostings JobPosting[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([deletedAt])
}

model Branch {
  id             String  @id @default(cuid())
  tenantId       String
  name           String
  workLocationId String?
  address        String?
  city           String?
  province       String?
  zipCode        String?
  isHeadOffice   Boolean @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  workLocation WorkLocation? @relation(fields: [workLocationId], references: [id])
  employees    Employee[]
  geofences    Geofence[]
  kiosks       Kiosk[]
  jobPostings  JobPosting[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([workLocationId])
  @@index([deletedAt])
}

model Position {
  id          String        @id @default(cuid())
  tenantId    String
  title       String
  level       PositionLevel @default(MID)
  description String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  employees Employee[]
  jobPostings JobPosting[]

  @@unique([tenantId, title])
  @@index([tenantId])
  @@index([deletedAt])
}

// =============================================================================
// CORE HRIS — Employee
// =============================================================================

model Employee {
  id       String  @id @default(cuid())
  tenantId String
  userId   String? @unique

  // Personal
  employeeNumber String
  firstName      String
  middleName     String?
  lastName       String
  suffix         String?
  preferredName  String?
  birthDate      DateTime?
  gender         Gender?
  civilStatus    CivilStatus?
  nationality    String?      @default("Filipino")

  // Contact
  personalEmail String?
  workEmail     String?
  mobileNumber  String?
  phoneNumber   String?

  // Address
  addressLine1 String?
  addressLine2 String?
  city         String?
  province     String?
  zipCode      String?
  region       String?

  // Employment
  departmentId       String?
  branchId           String?
  positionId         String?
  /// Free-text fallback when no Position row is assigned (legacy data).
  jobTitle           String?
  jobLevel           String?
  employmentStatus   EmploymentStatus @default(PROBATIONARY)
  employmentType     EmploymentType   @default(FULL_TIME)
  hireDate           DateTime
  regularizationDate DateTime?
  resignationDate    DateTime?
  lastWorkingDate    DateTime?
  endOfContractDate  DateTime?

  // Reporting chain (drives DTR + movement approval routing)
  immediateSupervisorId String?
  managerId             String?

  // Payroll
  payFrequency      PayFrequency @default(SEMI_MONTHLY)
  salaryType        SalaryType   @default(MONTHLY)
  standardWorkHours Decimal      @default(8) @db.Decimal(4, 2)
  standardWorkDays  Decimal      @default(22) @db.Decimal(4, 2)

  // Tax
  taxClassification          TaxClassification @default(REGULAR)
  /// For MWE: portion of basic pay considered non-taxable (centavos).
  nontaxableBasicAmountCents BigInt            @default(0)

  // ESS
  essPin       String? // hashed at app layer
  kioskPinHash String?
  qrBadgeCode  String?

  // Bank (encrypted at app layer)
  bankName          String?
  bankAccountNumber String?
  bankAccountName   String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  user       User?       @relation(fields: [userId], references: [id])
  department Department? @relation(fields: [departmentId], references: [id])
  branch     Branch?     @relation(fields: [branchId], references: [id])
  position   Position?   @relation(fields: [positionId], references: [id])

  immediateSupervisor Employee?  @relation("EmployeeSupervisor", fields: [immediateSupervisorId], references: [id])
  supervisorOf        Employee[] @relation("EmployeeSupervisor")
  manager             Employee?  @relation("EmployeeManager", fields: [managerId], references: [id])
  managerOf           Employee[] @relation("EmployeeManager")

  statutoryIds            StatutoryId[]
  salaryHistory           EmployeeSalary[]
  movements               EmployeeMovement[]
  incidentReports         IncidentReport[]
  assetAssignments        AssetAssignment[]
  documents               EmployeeDocument[]
  leaveBalances           LeaveBalance[]
  leaveTransactions       LeaveTransaction[]
  consentRecords          ConsentRecord[]
  payComponentAssignments EmployeePayComponent[]
  periodInputs            PeriodInput[]
  loans                   Loan[]
  payrollSheets           PayrollSheet[]
  payrollAdjustments      PayrollAdjustment[]
  shiftAssignments        EmployeeShiftAssignment[]
  dtrRecords              DTRRecord[]
  expenseClaims           ExpenseClaim[]
  essSessions             EssSession[]
  otApplications          OTApplication[]
  undertimeRequests       UndertimeRequest[]
  profileUpdateRequests   ProfileUpdateRequest[]
  attendanceLogs          AttendanceLog[]
  dtrSubmissions          DTRSubmission[]  @relation("DTRSubmissionEmployee")
  supervisedSubmissions   DTRSubmission[]  @relation("DTRSubmissionSupervisor")
  managedSubmissions      DTRSubmission[]  @relation("DTRSubmissionManager")

  defaultDtrApproverFor Tenant[] @relation("TenantDefaultDtrApprover")
  hiredFromApplicant    Applicant?

  @@unique([tenantId, employeeNumber])
  @@unique([tenantId, qrBadgeCode])
  @@index([tenantId])
  @@index([tenantId, employmentStatus])
  @@index([departmentId])
  @@index([branchId])
  @@index([positionId])
  @@index([immediateSupervisorId])
  @@index([managerId])
  @@index([deletedAt])
}

// =============================================================================
// STATUTORY IDs — normalized, one row per ID type
// Number value is encrypted at app layer.
// =============================================================================

model StatutoryId {
  id         String          @id @default(cuid())
  tenantId   String
  employeeId String
  type       StatutoryIdType
  /// Encrypted at app layer (AES-256-GCM) — never query by raw value.
  number     String
  /// HMAC-SHA256 of the plaintext number using HMAC_KEY.
  /// Used for duplicate-detection without exposing ciphertext.
  numberHmac String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, type])
  @@index([tenantId])
  @@index([type, numberHmac])
}

// =============================================================================
// EMPLOYEE DOCUMENTS (R2-backed)
// =============================================================================

model EmployeeDocument {
  id         String @id @default(cuid())
  employeeId String
  tenantId   String

  category    DocumentCategory
  title       String
  description String?

  storageKey String
  fileName   String
  mimeType   String
  fileSize   Int

  isConfidential Boolean @default(false)

  uploadedByUserId String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([tenantId])
  @@index([employeeId])
  @@index([category])
  @@index([deletedAt])
}

// =============================================================================
// SALARY HISTORY
// All monetary amounts stored as BigInt centavos.
// =============================================================================

model EmployeeSalary {
  id         String @id @default(cuid())
  employeeId String
  tenantId   String

  /// Basic salary for the period implied by salaryType, in centavos.
  basicSalaryCents BigInt
  salaryType       SalaryType

  effectiveDate DateTime
  endDate       DateTime?
  reason        String?

  createdByUserId String?
  createdAt       DateTime @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId, effectiveDate])
  @@index([tenantId])
}

// =============================================================================
// MOVEMENT FORMS
// =============================================================================

model EmployeeMovement {
  id           String       @id @default(cuid())
  tenantId     String
  employeeId   String
  movementType MovementType

  fromDepartmentId     String?
  toDepartmentId       String?
  fromBranchId         String?
  toBranchId           String?
  fromPositionId       String?
