  EXECUTIVE
}

enum StatutoryIdType {
  TIN
  SSS
  PHILHEALTH
  PAGIBIG
  GSIS
}

enum StatutoryCutoffRule {
  FIRST_CUTOFF
  SECOND_CUTOFF
}

enum ThirteenthMonthBasis {
  STRICT_DOLE
  INCLUDE_ALLOWANCES
