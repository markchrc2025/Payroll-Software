enum IncidentType {
  INCIDENT_REPORT
  NOTICE_TO_EXPLAIN
  NOTICE_OF_DECISION
  DISCIPLINARY_ACTION
  COMMENDATION
  MEMO
  OTHER
}

enum IncidentStatus {
