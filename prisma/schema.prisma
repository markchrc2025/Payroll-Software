// =============================================================================
// Sentire Payroll — Prisma Schema (Phase B2 realignment)
//
// Aligned to Sentire_Payroll_Master_Blueprint.md. Key conventions:
//   • Multi-tenant: every tenant-scoped row carries tenantId; Postgres RLS
//     enforces isolation (see migration 20260527_b2_rls).
//   • Money is stored as BigInt centavos (PHP); never use floats.
//   • Sensitive fields (TIN, SSS, PhilHealth, Pag-IBIG, GSIS, bank account)
//     are encrypted at the application layer via the Prisma client extension
//     in src/lib/crypto. The DB column type remains String.
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// ENUMS
// =============================================================================

enum SystemRole {
  SUPER_ADMIN
  TENANT_USER
}

enum PermissionModule {
  EMPLOYEES
  DEPARTMENTS
  BRANCHES
  PAYROLL
  TIMESHEETS
  LEAVES
  REPORTS
  COMPLIANCE
  SETTINGS
  ROLES
  INCIDENTS
  MOVEMENTS
  DOCUMENTS
  AUDIT
}

enum PermissionAction {
  CREATE
  READ
  UPDATE
  DELETE
  APPROVE
  EXPORT
}

enum SubscriptionTier {
  STARTER
  GROWTH
  PRO
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELLED
}

enum EmploymentStatus {
  PROBATIONARY
  REGULAR
  CONTRACTUAL
  PROJECT_BASED
  RESIGNED
  TERMINATED
  RETIRED
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CASUAL
}

enum PayFrequency {
  DAILY
  WEEKLY
  SEMI_MONTHLY
  MONTHLY
}

enum SalaryType {
  DAILY
  WEEKLY
  MONTHLY
}

/// Tax classification — drives BIR withholding and MWE rules.
enum TaxClassification {
  REGULAR
  MWE
}

enum CivilStatus {
  SINGLE
  MARRIED
  WIDOWED
  LEGALLY_SEPARATED
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  FOR_REVIEW
}

enum MovementType {
  DEPARTMENT_TRANSFER
  BRANCH_TRANSFER
  PROMOTION
  DEMOTION
  SALARY_ADJUSTMENT
  TITLE_CHANGE
  STATUS_CHANGE
  REGULARIZATION
}

enum IncidentType {
  INCIDENT_REPORT
  NOTICE_TO_EXPLAIN
  NOTICE_OF_DECISION
  DISCIPLINARY_ACTION
  COMMENDATION
  MEMO
  OTHER
}

enum IncidentStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  CLOSED
  ESCALATED
}

enum DocumentCategory {
  CONTRACT
  VALID_ID
  GOVERNMENT_FORM
  MEDICAL
  RESUME
  EDUCATION
  TRAINING_CERT
  PERFORMANCE
  CLEARANCE
  TAX
  OTHER
}

enum LeaveUnit {
  DAYS
  HOURS
}

enum AccrualFrequency {
  MONTHLY
  QUARTERLY
  ANNUALLY
  UPON_REGULARIZATION
  LUMP_SUM
}

enum LeaveTransactionType {
  ACCRUAL
  USAGE
  ADJUSTMENT
  CARRYOVER
  FORFEITURE
  CONVERSION
}

enum PositionLevel {
  ENTRY
  MID
  SENIOR
  MANAGER
  DIRECTOR
  EXECUTIVE
}

enum StatutoryIdType {
  TIN
  SSS
  PHILHEALTH
  PAGIBIG
  GSIS
}

enum StatutoryCutoffRule {
  FIRST_CUTOFF
  SECOND_CUTOFF
}

enum ThirteenthMonthBasis {
  STRICT_DOLE
  INCLUDE_ALLOWANCES
}

/// Audit log target kinds — kept open via String for forward-compat.
enum AuditAction {
  CREATE
  UPDATE
  DELETE
  READ
  APPROVE
  REJECT
  EXPORT
  LOGIN
  LOGOUT
  IMPERSONATE
}

enum ConsentType {
  BIOMETRIC_SELFIE
  GEOLOCATION
  KIOSK_PHOTO
  DATA_PROCESSING
  MARKETING
}

enum AiTouchpoint {
  DOC_EXTRACTION
  HR_CHAT
  PAYSLIP_QA
  COMPLIANCE_HELPER
  RESUME_PARSE
  ANOMALY_FLAGGING
}

/// Statutory rule category (Phase D1). Each row in `StatutoryRule` carries a
/// polymorphic JSON `payload` whose shape is validated at the application
/// layer via zod (`src/lib/statutory/types.ts`).
enum StatutoryCategory {
  SSS_SCHEDULE
  PHILHEALTH_SCHEDULE
  PAGIBIG_SCHEDULE
  BIR_WITHHOLDING_TABLE
  DE_MINIMIS_CEILING
  MINIMUM_WAGE_RATE
}

// ---------------------------------------------------------------------------
// PAYROLL DOMAIN (Phase D2)
// ---------------------------------------------------------------------------

/// Broad family of a pay component. Drives default sign (earning vs deduction)
/// and the default taxability override matrix in the engine.
enum PayComponentKind {
  ALLOWANCE
  BONUS
  COMMISSION
  OTHER_EARNING
  REIMBURSEMENT
  DEDUCTION
}

/// Tax treatment of a pay component.
///   • TAXABLE — added to taxable gross.
///   • NON_TAXABLE — added to gross but not to BIR taxable base.
///   • DE_MINIMIS — subject to the RR 29-2025 ceiling (excess is taxable);
///                  `deMinimisCode` MUST be set and must reference a code from
///                  the active `DE_MINIMIS_CEILING` payload.
///   • STATUTORY_EXEMPT — mandatory contributions / 13th-month residual; engine
///                        emits these, not the catalog.
enum PayComponentTaxability {
  TAXABLE
  NON_TAXABLE
  DE_MINIMIS
  STATUTORY_EXEMPT
}

/// Loan source. Drives default ledger account and government-loan amortization
/// rules.
enum LoanType {
  SSS
  PAGIBIG
  CASH_ADVANCE
  COMPANY
}

enum LoanStatus {
  ACTIVE
  PAID
  CANCELLED
  ON_HOLD
}

/// Payroll run lifecycle. DRAFT → FINALIZED is a one-way transition (writes
/// AuditLog + decrements loan balances). CANCELLED is reserved for runs that
/// were created in error before finalize.
enum PayrollBookStatus {
  DRAFT
  FINALIZED
  CANCELLED
}

enum PayrollRunType {
  REGULAR
  OFF_CYCLE
  FINAL_PAY
  YEAR_END
}

enum AdjustmentKind {
  ADDITION
  DEDUCTION
}

/// Reason an employee's employment was terminated.  Drives DOLE separation-pay
/// formula and BIR taxability rules for the FINAL_PAY run.
enum SeparationReason {
  /// Voluntary resignation — no statutory separation pay; any gratuity is taxable.
  RESIGNATION
  /// Mutually agreed separation — no statutory separation pay.
  MUTUAL_AGREEMENT
  /// End of project / fixed-term contract — no statutory separation pay.
  END_OF_CONTRACT
  /// Art. 298 RA 10361 — 1 month per year (or fraction ≥ 6 mo) of service.
  REDUNDANCY
  /// Art. 298 — 0.5 month per year (min 1 month); exempt from WHT.
  RETRENCHMENT
  /// Art. 298 — 1 month per year when not due to serious losses; exempt from WHT.
  CLOSURE_OF_BUSINESS
  /// Art. 299 — disease not curable within 6 months; 1 month per year; exempt.
  DISEASE
  /// Art. 297 — dismissal for just cause; no separation pay by law.
  JUST_CAUSE
}

// =============================================================================
// DTR / TIMESHEET ENUMS (Phase J)
// =============================================================================

enum ShiftType {
  FIXED
  FLEXIBLE
}

enum DTRStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DTRDayStatus {
  PRESENT
  ABSENT
  PAID_LEAVE
  UNPAID_LEAVE
  HOLIDAY
  REST_DAY
}

// =============================================================================
// TENANT (SaaS customer)
// =============================================================================

model Tenant {
  id        String  @id @default(cuid())
  name      String
  tradeName String?
  subdomain String? @unique
  industry  String?

  // Encrypted at app layer
  tinNumber        String? @unique
  sssNumber        String?
  philhealthNumber String?
  pagibigNumber    String?

  address      String?
  city         String?
  province     String?
  zipCode      String?
  country      String  @default("Philippines")
  contactEmail String?
  contactPhone String?
  logoUrl      String?

  // Subscription
  subscriptionTier   SubscriptionTier   @default(STARTER)
  subscriptionStatus SubscriptionStatus @default(TRIALING)
  trialEndsAt        DateTime?
  billingEmail       String?

  /// Per-tenant feature toggles (e.g. {"ai_assistant": true, "ats": false}).
  featureFlags Json @default("{}")

  // Payroll defaults (§9 of blueprint)
  payrollCycle           PayFrequency         @default(SEMI_MONTHLY)
  workingDaysDenominator Int                  @default(261)
  statutoryCutoffRule    StatutoryCutoffRule  @default(SECOND_CUTOFF)
  thirteenthMonthBasis   ThirteenthMonthBasis @default(STRICT_DOLE)
  defaultDtrApproverId   String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  users                 User[]
  roles                 Role[]
  departments           Department[]
  branches              Branch[]
  workLocations         WorkLocation[]
  positions             Position[]
  employees             Employee[]
  statutoryIds          StatutoryId[]
  employeeSalaries      EmployeeSalary[]
  employeeMovements     EmployeeMovement[]
  incidentReports       IncidentReport[]
  employeeDocuments     EmployeeDocument[]
  geofences             Geofence[]
  kiosks                Kiosk[]
  leaveTypes            LeaveType[]
  leaveTransactions     LeaveTransaction[]
  dtrApprovalConfig     DTRApprovalConfig?
  auditLogs             AuditLog[]
  consentRecords        ConsentRecord[]
  aiUsage               AiUsage[]
  statutoryRules        StatutoryRule[]
  payComponents         PayComponent[]
  employeePayComponents EmployeePayComponent[]
  periodInputs          PeriodInput[]
  loans                 Loan[]
  payrollBooks          PayrollBook[]
  payrollSheets         PayrollSheet[]
  payrollAdjustments    PayrollAdjustment[]
  shiftSchedules        ShiftSchedule[]
  shiftAssignments      EmployeeShiftAssignment[]
  dtrRecords            DTRRecord[]
  expenseClaims         ExpenseClaim[]
  essSessions           EssSession[]
  otApplications        OTApplication[]
  profileUpdateRequests ProfileUpdateRequest[]

  defaultDtrApprover Employee? @relation("TenantDefaultDtrApprover", fields: [defaultDtrApproverId], references: [id])

  @@index([deletedAt])
}

// =============================================================================
// USERS & RBAC
// =============================================================================

model User {
  id           String  @id @default(cuid())
  tenantId     String? // NULL for SUPER_ADMIN users
  email        String
  passwordHash String
  firstName    String
  lastName     String

  systemRole SystemRole @default(TENANT_USER)
  roleId     String?

  essPinHash String?

  isActive    Boolean   @default(true)
  lastLoginAt DateTime?

  twoFactorEnabled Boolean @default(false)
  twoFactorSecret  String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant       Tenant?   @relation(fields: [tenantId], references: [id])
  assignedRole Role?     @relation(fields: [roleId], references: [id])
  employee     Employee?
  approvedExpenseClaims ExpenseClaim[] @relation("ExpenseClaimApprover")

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([roleId])
  @@index([deletedAt])
}

model Role {
  id          String  @id @default(cuid())
  tenantId    String
  name        String
  description String?
  isSystem    Boolean @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant      Tenant           @relation(fields: [tenantId], references: [id])
  permissions RolePermission[]
  users       User[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([deletedAt])
}

model Permission {
  id     String           @id @default(cuid())
  module PermissionModule
  action PermissionAction
  label  String

  roles RolePermission[]

  @@unique([module, action])
}

model RolePermission {
  roleId           String
  permissionId     String
  departmentScoped Boolean @default(false)

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

// =============================================================================
// ORG STRUCTURE
// =============================================================================

model WorkLocation {
  id       String  @id @default(cuid())
  tenantId String
  name     String
  /// PSGC / DOLE region code — drives minimum-wage lookup (e.g. "NCR", "CAR", "07").
  region   String
  address  String?
  city     String?
  province String?
  zipCode  String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  branches Branch[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([deletedAt])
}

model Department {
  id          String  @id @default(cuid())
  tenantId    String
  name        String
  description String?
  managerId   String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  employees Employee[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([deletedAt])
}

model Branch {
  id             String  @id @default(cuid())
  tenantId       String
  name           String
  workLocationId String?
  address        String?
  city           String?
  province       String?
  zipCode        String?
  isHeadOffice   Boolean @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  workLocation WorkLocation? @relation(fields: [workLocationId], references: [id])
  employees    Employee[]
  geofences    Geofence[]
  kiosks       Kiosk[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([workLocationId])
  @@index([deletedAt])
}

model Position {
  id          String        @id @default(cuid())
  tenantId    String
  title       String
  level       PositionLevel @default(MID)
  description String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  employees Employee[]

  @@unique([tenantId, title])
  @@index([tenantId])
  @@index([deletedAt])
}

// =============================================================================
// CORE HRIS — Employee
// =============================================================================

model Employee {
  id       String  @id @default(cuid())
  tenantId String
  userId   String? @unique

  // Personal
  employeeNumber String
  firstName      String
  middleName     String?
  lastName       String
  suffix         String?
  preferredName  String?
  birthDate      DateTime?
  gender         Gender?
  civilStatus    CivilStatus?
  nationality    String?      @default("Filipino")

  // Contact
  personalEmail String?
  workEmail     String?
  mobileNumber  String?
  phoneNumber   String?

  // Address
  addressLine1 String?
  addressLine2 String?
  city         String?
  province     String?
  zipCode      String?
  region       String?

  // Employment
  departmentId       String?
  branchId           String?
  positionId         String?
  /// Free-text fallback when no Position row is assigned (legacy data).
  jobTitle           String?
  jobLevel           String?
  employmentStatus   EmploymentStatus @default(PROBATIONARY)
  employmentType     EmploymentType   @default(FULL_TIME)
  hireDate           DateTime
  regularizationDate DateTime?
  resignationDate    DateTime?
  lastWorkingDate    DateTime?
  endOfContractDate  DateTime?

  // Reporting chain (drives DTR + movement approval routing)
  immediateSupervisorId String?
  managerId             String?

  // Payroll
  payFrequency      PayFrequency @default(SEMI_MONTHLY)
  salaryType        SalaryType   @default(MONTHLY)
  standardWorkHours Decimal      @default(8) @db.Decimal(4, 2)
  standardWorkDays  Decimal      @default(22) @db.Decimal(4, 2)

  // Tax
  taxClassification          TaxClassification @default(REGULAR)
  /// For MWE: portion of basic pay considered non-taxable (centavos).
  nontaxableBasicAmountCents BigInt            @default(0)

  // ESS
  essPin       String? // hashed at app layer
  kioskPinHash String?
  qrBadgeCode  String?

  // Bank (encrypted at app layer)
  bankName          String?
  bankAccountNumber String?
  bankAccountName   String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  user       User?       @relation(fields: [userId], references: [id])
  department Department? @relation(fields: [departmentId], references: [id])
  branch     Branch?     @relation(fields: [branchId], references: [id])
  position   Position?   @relation(fields: [positionId], references: [id])

  immediateSupervisor Employee?  @relation("EmployeeSupervisor", fields: [immediateSupervisorId], references: [id])
  supervisorOf        Employee[] @relation("EmployeeSupervisor")
  manager             Employee?  @relation("EmployeeManager", fields: [managerId], references: [id])
  managerOf           Employee[] @relation("EmployeeManager")

  statutoryIds            StatutoryId[]
  salaryHistory           EmployeeSalary[]
  movements               EmployeeMovement[]
  incidentReports         IncidentReport[]
  documents               EmployeeDocument[]
  leaveBalances           LeaveBalance[]
  leaveTransactions       LeaveTransaction[]
  consentRecords          ConsentRecord[]
  payComponentAssignments EmployeePayComponent[]
  periodInputs            PeriodInput[]
  loans                   Loan[]
  payrollSheets           PayrollSheet[]
  payrollAdjustments      PayrollAdjustment[]
  shiftAssignments        EmployeeShiftAssignment[]
  dtrRecords              DTRRecord[]
  expenseClaims           ExpenseClaim[]
  essSessions             EssSession[]
  otApplications          OTApplication[]
  profileUpdateRequests   ProfileUpdateRequest[]

  defaultDtrApproverFor Tenant[] @relation("TenantDefaultDtrApprover")

  @@unique([tenantId, employeeNumber])
  @@unique([tenantId, qrBadgeCode])
  @@index([tenantId])
  @@index([tenantId, employmentStatus])
  @@index([departmentId])
  @@index([branchId])
  @@index([positionId])
  @@index([immediateSupervisorId])
  @@index([managerId])
  @@index([deletedAt])
}

// =============================================================================
// STATUTORY IDs — normalized, one row per ID type
// Number value is encrypted at app layer.
// =============================================================================

model StatutoryId {
  id         String          @id @default(cuid())
  tenantId   String
  employeeId String
  type       StatutoryIdType
  /// Encrypted at app layer (AES-256-GCM) — never query by raw value.
  number     String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, type])
  @@index([tenantId])
}

// =============================================================================
// EMPLOYEE DOCUMENTS (R2-backed)
// =============================================================================

model EmployeeDocument {
  id         String @id @default(cuid())
  employeeId String
  tenantId   String

  category    DocumentCategory
  title       String
  description String?

  storageKey String
  fileName   String
  mimeType   String
  fileSize   Int

  isConfidential Boolean @default(false)

  uploadedByUserId String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([tenantId])
  @@index([employeeId])
  @@index([category])
  @@index([deletedAt])
}

// =============================================================================
// SALARY HISTORY
// All monetary amounts stored as BigInt centavos.
// =============================================================================

model EmployeeSalary {
  id         String @id @default(cuid())
  employeeId String
  tenantId   String

  /// Basic salary for the period implied by salaryType, in centavos.
  basicSalaryCents BigInt
  salaryType       SalaryType

  effectiveDate DateTime
  endDate       DateTime?
  reason        String?

  createdByUserId String?
  createdAt       DateTime @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId, effectiveDate])
  @@index([tenantId])
}

// =============================================================================
// MOVEMENT FORMS
// =============================================================================

model EmployeeMovement {
  id           String       @id @default(cuid())
  tenantId     String
  employeeId   String
  movementType MovementType

  fromDepartmentId     String?
  toDepartmentId       String?
  fromBranchId         String?
  toBranchId           String?
  fromPositionId       String?
  toPositionId         String?
  fromJobTitle         String?
  toJobTitle           String?
  fromJobLevel         String?
  toJobLevel           String?
  fromBasicSalaryCents BigInt?
  toBasicSalaryCents   BigInt?
  fromStatus           EmploymentStatus?
  toStatus             EmploymentStatus?

  effectiveDate DateTime
  reason        String?
  notes         String?
  documentUrl   String?

  approvalStatus   ApprovalStatus @default(PENDING)
  approvedByUserId String?
  approvedAt       DateTime?
  rejectionReason  String?

  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([tenantId])
  @@index([employeeId, effectiveDate])
}

// =============================================================================
// INCIDENT MANAGEMENT
// =============================================================================

model IncidentReport {
  id         String         @id @default(cuid())
  tenantId   String
  employeeId String
  type       IncidentType
  status     IncidentStatus @default(OPEN)

  subject      String
  description  String
  incidentDate DateTime

  responseDeadline DateTime?
  employeeResponse String?

  attachmentUrls Json @default("[]")

  resolution       String?
  resolvedAt       DateTime?
  resolvedByUserId String?

  createdByUserId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([tenantId])
  @@index([employeeId])
  @@index([deletedAt])
}

// =============================================================================
// GPS GEOFENCING
// =============================================================================

model Geofence {
  id       String  @id @default(cuid())
  tenantId String
  branchId String?
  name     String

  latitude     Decimal @db.Decimal(10, 7)
  longitude    Decimal @db.Decimal(10, 7)
  radiusMeters Int     @default(50)
  isActive     Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant Tenant  @relation(fields: [tenantId], references: [id])
  branch Branch? @relation(fields: [branchId], references: [id])

  @@index([tenantId])
  @@index([branchId])
  @@index([deletedAt])
}

// =============================================================================
// LEAVE
// =============================================================================

model LeaveType {
  id                  String    @id @default(cuid())
  tenantId            String
  name                String
  code                String
  description         String?
  isPaid              Boolean   @default(true)
  isConvertibleToCash Boolean   @default(false)
  unit                LeaveUnit @default(DAYS)

  accrualFrequency    AccrualFrequency @default(MONTHLY)
  accrualAmount       Decimal          @db.Decimal(6, 4)
  maxAccruableBalance Decimal?         @db.Decimal(6, 4)
  carryOverLimit      Decimal?         @db.Decimal(6, 4)

  requiresRegularization Boolean @default(false)

  isActive Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant       Tenant             @relation(fields: [tenantId], references: [id])
  balances     LeaveBalance[]
  transactions LeaveTransaction[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([deletedAt])
}

model LeaveBalance {
  id          String @id @default(cuid())
  tenantId    String
  employeeId  String
  leaveTypeId String
  year        Int

  openingBalance  Decimal @default(0) @db.Decimal(8, 4)
  earned          Decimal @default(0) @db.Decimal(8, 4)
  used            Decimal @default(0) @db.Decimal(8, 4)
  forfeited       Decimal @default(0) @db.Decimal(8, 4)
  convertedToCash Decimal @default(0) @db.Decimal(8, 4)

  updatedAt DateTime @updatedAt

  employee  Employee  @relation(fields: [employeeId], references: [id])
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id])

  @@unique([employeeId, leaveTypeId, year])
  @@index([tenantId])
  @@index([employeeId])
}

model LeaveTransaction {
  id             String @id @default(cuid())
  tenantId       String
  employeeId     String
  leaveTypeId    String
  leaveBalanceId String

  type   LeaveTransactionType
  amount Decimal              @db.Decimal(8, 4)

  startDate      DateTime?
  endDate        DateTime?
  reason         String?
  attachmentUrls Json      @default("[]")

  approvalStatus   ApprovalStatus @default(PENDING)
  approvedByUserId String?
  approvedAt       DateTime?
  rejectionReason  String?

  createdByUserId String?
  createdAt       DateTime @default(now())

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  employee  Employee  @relation(fields: [employeeId], references: [id])
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id])

  @@index([tenantId])
  @@index([employeeId, leaveTypeId])
  @@index([approvalStatus])
}

// =============================================================================
// DTR APPROVAL CONFIG
// =============================================================================

model DTRApprovalConfig {
  id       String @id @default(cuid())
  tenantId String @unique

  requiresEmployeeSubmission     Boolean @default(true)
  requiresSupervisorVerification Boolean @default(true)
  requiresManagerApproval        Boolean @default(true)

  employeeSubmitDeadlineHours Int @default(48)
  supervisorDeadlineHours     Int @default(24)
  managerDeadlineHours        Int @default(24)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
}

// =============================================================================
// KIOSK
// =============================================================================

model Kiosk {
  id       String  @id @default(cuid())
  tenantId String
  branchId String?
  name     String

  deviceToken String @unique @default(cuid())

  requiresSelfie Boolean @default(true)
  isActive       Boolean @default(true)

  lastSeenAt DateTime?

  createdByUserId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  tenant Tenant  @relation(fields: [tenantId], references: [id])
  branch Branch? @relation(fields: [branchId], references: [id])

  @@index([tenantId])
  @@index([branchId])
  @@index([deletedAt])
}

// =============================================================================
// AUDIT LOG — append-only record of every CUD + sensitive read
// =============================================================================

model AuditLog {
  id          String      @id @default(cuid())
  tenantId    String
  actorUserId String?
  action      AuditAction
  /// Logical entity name, e.g. "Employee", "PayrollRun".
  entity      String
  entityId    String?
  /// Snapshot of changes — typically { before: {...}, after: {...} }.
  changes     Json?
  ipAddress   String?
  userAgent   String?

  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, createdAt])
  @@index([tenantId, entity, entityId])
  @@index([actorUserId])
}

// =============================================================================
// CONSENT RECORD — DPA 10173 compliance for biometric/location capture
// =============================================================================

model ConsentRecord {
  id            String      @id @default(cuid())
  tenantId      String
  employeeId    String
  type          ConsentType
  granted       Boolean
  /// Free-text policy/version identifier shown at consent time (e.g. "v2026-01").
  policyVersion String
  ipAddress     String?
  userAgent     String?

  grantedAt DateTime  @default(now())
  revokedAt DateTime?

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([tenantId, employeeId, type])
}

// =============================================================================
// AI USAGE METERING
// =============================================================================

model AiUsage {
  id           String       @id @default(cuid())
  tenantId     String
  userId       String?
  touchpoint   AiTouchpoint
  model        String // e.g. "claude-haiku-4.5"
  inputTokens  Int          @default(0)
  outputTokens Int          @default(0)
  /// Cached input tokens (Anthropic prompt caching). Subset of inputTokens.
  cachedTokens Int          @default(0)
  /// Cost in micro-USD (1 USD = 1_000_000) to keep integer arithmetic.
  costMicroUsd BigInt       @default(0)
  latencyMs    Int?

  /// Free-form correlation key (request id, payroll run id, etc.)
  refKey String?

  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, createdAt])
  @@index([tenantId, touchpoint])
}

// =============================================================================
// STATUTORY CONFIGURATION ENGINE (Phase D1)
//
// Effective-dated rule store. One row per (category, version, optional tenant).
// `tenantId IS NULL` rows are the global baseline (BIR/SSS/PhilHealth/HDMF
// published values). Non-null rows are per-tenant overrides — currently only
// DE_MINIMIS_CEILING and MINIMUM_WAGE_RATE accept overrides via the app layer
// (`MINIMUM_WAGE_RATE` overrides below the global floor are hard-rejected at
// the route boundary).
//
// `payload` is a JSON blob whose shape is enforced by zod schemas in
// `src/lib/statutory/types.ts`. The resolver in `src/lib/statutory/resolver.ts`
// always prefers a tenant-scoped row when one is active for the asOf date.
//
// RLS: see migration `20260527090000_d1_statutory_rules`. Reads allow
// `tenantId IS NULL OR tenantId = current_setting(...)`. Writes require
// `tenantId = current_setting(...)` (global rows are owner-only, loaded via
// the seed script running as the migration superuser).
// =============================================================================

model StatutoryRule {
  id            String            @id @default(cuid())
  /// NULL = global default; non-null = tenant override.
  tenantId      String?
  category      StatutoryCategory
  /// Inclusive lower bound. Rule is active for asOfDate >= effectiveFrom.
  effectiveFrom DateTime
  /// Exclusive upper bound. NULL = open-ended.
  effectiveTo   DateTime?
  /// Citation of the legal basis (e.g. "RA 11199 + SSS Circular 2025-006").
  legalBasis    String
  /// Human/script-readable version tag (e.g. "SSS-2026-v1", "TRAIN-2023-onward-v1").
  version       String
  /// Polymorphic payload — shape per category enforced by zod at runtime.
  payload       Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id])

  /// One row per (tenantOrGlobal, category, version). Tenant overrides and
  /// global rules can coexist; resolver picks tenant first.
  @@unique([tenantId, category, version])
  @@index([category, effectiveFrom])
  @@index([tenantId, category, effectiveFrom])
}

// =============================================================================
// PAY COMPONENT CATALOG (Phase D2)
//
// Tenant-scoped catalog of recurring or ad-hoc earnings & deductions consumed
// by the gross-to-net engine. The catalog does NOT include statutory
// contributions (SSS / PhilHealth / Pag-IBIG / BIR) — those are computed by
// the engine using `StatutoryRule` rows.
// =============================================================================

model PayComponent {
  id       String @id @default(cuid())
  tenantId String

  /// Stable short code, e.g. "RICE", "MEAL", "BONUS_PERFY". Unique per tenant.
  code          String
  /// Human-facing display name.
  name          String
  kind          PayComponentKind
  taxability    PayComponentTaxability @default(TAXABLE)
  /// Required iff `taxability = DE_MINIMIS`. Must match a code in the active
  /// `DE_MINIMIS_CEILING` payload at compute time.
  deMinimisCode String?

  /// Whether amount counts toward the 13th-month-pay basis.
  includeIn13thMonth      Boolean @default(false)
  /// Whether amount counts toward the SSS / PhilHealth / Pag-IBIG MSC bases.
  /// Government rules currently treat MSC bases identically (basic + regular
  /// allowances); the flag is split per fund to allow future drift.
  includeInSssBase        Boolean @default(false)
  includeInPhilHealthBase Boolean @default(false)
  includeInPagibigBase    Boolean @default(false)

  isActive Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant      Tenant                 @relation(fields: [tenantId], references: [id])
  assignments EmployeePayComponent[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, kind])
  @@index([deletedAt])
}

/// Effective-dated assignment of a `PayComponent` to an `Employee` with an
/// amount expressed in centavos. The engine resolves the active assignment
/// for a given period by `effectiveFrom <= periodEnd AND (endDate IS NULL OR
/// endDate >= periodStart)`.
model EmployeePayComponent {
  id             String @id @default(cuid())
  tenantId       String
  employeeId     String
  payComponentId String

  /// Amount in centavos. For recurring components this is the per-pay-period
  /// amount; the engine pro-rates by `daysWorked` only when the component is
  /// marked as basic-pay-proportional (deferred — for now amounts are flat).
  amountCents BigInt

  effectiveFrom DateTime
  /// Inclusive upper bound. NULL = open-ended.
  endDate       DateTime?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  employee     Employee     @relation(fields: [employeeId], references: [id])
  payComponent PayComponent @relation(fields: [payComponentId], references: [id])

  @@index([tenantId])
  @@index([tenantId, employeeId])
  @@index([employeeId, payComponentId, effectiveFrom])
}

// =============================================================================
// PERIOD INPUTS (Phase D2)
//
// Captures engine inputs for ONE employee for ONE pay period. Created either
// (a) manually by HR/payroll for shops without DTR ingestion, or (b) populated
// from approved DTRs in a later phase. One row per (employee, periodStart,
// periodEnd).
//
// Time fields are stored as Decimal(10,4); the engine multiplies against the
// employee's hourly rate (in centavos) and uses BigInt arithmetic to land on
// centavos.
// =============================================================================

model PeriodInput {
  id         String @id @default(cuid())
  tenantId   String
  employeeId String

  periodStart DateTime
  periodEnd   DateTime

  /// Actual days rendered in the period. Fractional days allowed (half-days,
  /// suspended ops). Defaults to 0 — caller MUST set explicitly.
  daysWorked           Decimal @default(0) @db.Decimal(6, 2)
  /// Aggregate tardiness + undertime in minutes.
  lateUndertimeMinutes Int     @default(0)

  regularOtHours      Decimal @default(0) @db.Decimal(6, 2)
  restDayHours        Decimal @default(0) @db.Decimal(6, 2)
  specialHolidayHours Decimal @default(0) @db.Decimal(6, 2)
  regularHolidayHours Decimal @default(0) @db.Decimal(6, 2)
  nightDiffHours      Decimal @default(0) @db.Decimal(6, 2)
  hazardHours         Decimal @default(0) @db.Decimal(6, 2)

  unpaidLeaveDays Decimal @default(0) @db.Decimal(6, 2)

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([tenantId, employeeId, periodStart, periodEnd])
  @@index([tenantId])
  @@index([tenantId, periodStart, periodEnd])
  @@index([employeeId, periodStart])
}

// =============================================================================
// LOANS (Phase D2)
//
// Government (SSS / Pag-IBIG) or in-house loans. The engine deducts
// `installmentCents` from net pay per active loan and decrements `balanceCents`
// after each successful payroll run (deferred to D3 finalize).
// =============================================================================

model Loan {
  id         String @id @default(cuid())
  tenantId   String
  employeeId String

  loanType        LoanType
  /// External reference (SSS loan number, contract number, etc.).
  referenceNumber String?

  principalCents   BigInt
  installmentCents BigInt
  balanceCents     BigInt

  status LoanStatus @default(ACTIVE)

  startDate  DateTime
  /// Date the loan was fully paid / cancelled. Engine-set on terminal
  /// transitions.
  closedDate DateTime?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([tenantId])
  @@index([tenantId, employeeId, status])
  @@index([tenantId, status])
}

// =============================================================================
// PAYROLL RUN — PayrollBook + PayrollSheet (Phase D3)
//
// A `PayrollBook` represents one payroll run for a tenant × period × runType.
// While `status = DRAFT`, sheets can be recomputed (delete-and-regenerate).
// On `FINALIZED`, the book is immutable: loan balances are decremented and an
// `AuditLog` entry is written in the same tx. Corrections after finalize use
// off-cycle runs (`runType = OFF_CYCLE`), never in-place edits.
// =============================================================================

model PayrollBook {
  id       String @id @default(cuid())
  tenantId String

  periodStart DateTime
  periodEnd   DateTime
  cycle       PayFrequency
  runType     PayrollRunType    @default(REGULAR)
  status      PayrollBookStatus @default(DRAFT)

  notes String?

  /// When true the engine skips SSS/PhilHealth/Pag-IBIG deductions for every
  /// sheet in this run (WHT is still computed).  Primarily for OFF_CYCLE
  /// bonus runs where statutory was already collected in the regular cycle.
  skipStatutory Boolean @default(false)

  /// Only set for FINAL_PAY runs.  Drives DOLE separation-pay formula and
  /// BIR taxability; preserved on the book so recomputeRun is idempotent.
  separationReason SeparationReason?

  createdByUserId   String?
  finalizedAt       DateTime?
  finalizedByUserId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant      Tenant              @relation(fields: [tenantId], references: [id])
  sheets      PayrollSheet[]
  adjustments PayrollAdjustment[]
  expenseClaims     ExpenseClaim[]     @relation("BookExpenseClaims")
  paidExpenseClaims ExpenseClaim[]     @relation("BookPaidExpenseClaims")

  @@unique([tenantId, periodStart, periodEnd, runType])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, periodEnd])
}

/// One frozen pay-stub computation per employee per run. All monetary fields
/// are BigInt centavos. Snapshot fields capture the inputs used so the row
/// remains explainable even if the underlying master data changes later.
model PayrollSheet {
  id            String @id @default(cuid())
  tenantId      String
  payrollBookId String
  employeeId    String

  // -- Snapshots (master data captured at compute time) ---------------------
  taxClassificationSnapshot      TaxClassification
  /// Region code from the employee's branch.workLocation at compute time.
  regionSnapshot                 String?
  payFrequencySnapshot           PayFrequency
  salaryTypeSnapshot             SalaryType
  basicSalaryCentsSnapshot       BigInt
  workingDaysDenominatorSnapshot Int
  /// Whether statutory contributions were deducted in this run (driven by
  /// tenant's `statutoryCutoffRule` and the period's position in the month).
  statutoryDeductedSnapshot      Boolean

  // -- Step 1: Base pay (after late/undertime) ------------------------------
  basePayCents                BigInt @default(0)
  lateUndertimeDeductionCents BigInt @default(0)

  // -- Step 3: Premium pay (broken out for payslip readability) -------------
  otPayCents      BigInt @default(0)
  nsdPayCents     BigInt @default(0)
  holidayPayCents BigInt @default(0)
  hazardPayCents  BigInt @default(0)
  restDayPayCents BigInt @default(0)

  // -- Step 4: Pay components -----------------------------------------------
  taxableAllowancesCents BigInt @default(0)

  // -- Step 5/6: Gross + non-taxable buckets --------------------------------
  grossCompensationCents            BigInt @default(0)
  mweExemptCompensationCents        BigInt @default(0)
  nontaxableBasicCents              BigInt @default(0)
  nontaxableCompensationCents       BigInt @default(0)
  nontaxable13MonthAndBenefitsCents BigInt @default(0)

  // -- Step 7: Taxable -------------------------------------------------------
  grossTaxableIncomeCents BigInt @default(0)

  // -- Step 8: Statutory contributions --------------------------------------
  sssEeCents        BigInt @default(0)
  sssErCents        BigInt @default(0)
  sssEcCents        BigInt @default(0)
  philhealthEeCents BigInt @default(0)
  philhealthErCents BigInt @default(0)
  pagibigEeCents    BigInt @default(0)
  pagibigErCents    BigInt @default(0)

  // -- Step 9: Withholding tax ----------------------------------------------
  withholdingTaxCents BigInt @default(0)

  // -- Step 10/11: Add-backs and deductions ---------------------------------
  nontaxableAdditionsCents BigInt @default(0)
  loanDeductionsCents      BigInt @default(0)

  // -- Step 12: Final --------------------------------------------------------
  netPayCents BigInt @default(0)

  // -- Polymorphic breakdowns for payslip / audit ---------------------------
  /// Array of { id, code, name, kind, taxability, amountCents }.
  payComponentsApplied Json @default("[]")
  /// Array of { loanId, type, amountCents, balanceBeforeCents, balanceAfterCents }.
  /// Populated at compute; `balanceAfterCents` only authoritative once the run
  /// is FINALIZED (engine debits the loan during finalize tx).
  loanPaymentsApplied  Json @default("[]")
  /// Snapshot of the PeriodInput row used (days/hours/minutes).
  periodInputSnapshot  Json @default("{}")
  /// Per-fund SSS/PhilHealth/Pag-IBIG raw breakdown (msc, regular, mpf, ec).
  statutoryBreakdown   Json  @default("{}")
  /// FINAL_PAY-only: back pay, prorated 13th, leave cash-out, separation pay,
  /// annualization inputs/outputs.  Null for REGULAR / OFF_CYCLE / YEAR_END.
  finalPayBreakdown    Json?
  /// YEAR_END-only: year-end annualization true-up result.  Written by the
  /// POST /api/payroll/runs/[id]/annualize endpoint after finalization.
  annualizationData    Json?
  /// Array of { id, kind, amountCents, isTaxable, reason } applied in this run.
  adjustmentsApplied   Json?
  /// Array of { id, category, amountCents, taxTreatment, taxablePortionCents, nontaxablePortionCents }.
  expenseClaimsApplied Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  payrollBook PayrollBook @relation(fields: [payrollBookId], references: [id], onDelete: Cascade)
  employee    Employee    @relation(fields: [employeeId], references: [id])

  @@unique([payrollBookId, employeeId])
  @@index([tenantId])
  @@index([tenantId, employeeId])
  @@index([payrollBookId])
}

/// One-off monetary addition or deduction applied to a specific DRAFT payroll
/// run.  Created by payroll operators before finalizing the book; consumed by
/// the engine in the gross-to-net waterfall.
model PayrollAdjustment {
  id            String         @id @default(cuid())
  tenantId      String
  employeeId    String
  payrollBookId String

  /// Whether this is a positive addition or a negative deduction.
  kind        AdjustmentKind
  /// Always stored as a positive value; `kind` determines the sign direction.
  amountCents BigInt
  /// True → included in gross compensation (taxable); False → added back
  /// after WHT as a non-taxable reimbursement/allowance.
  isTaxable   Boolean @default(true)
  /// Required audit trail (e.g. "Bonus adjustment", "Salary overpayment").
  reason      String  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  employee    Employee    @relation(fields: [employeeId], references: [id])
  payrollBook PayrollBook @relation(fields: [payrollBookId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([payrollBookId])
  @@index([employeeId])
}

// =============================================================================
// EXPENSE CLAIMS (Phase K)
// =============================================================================

enum ExpenseClaimStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  ATTACHED
  PAID
}

enum ExpenseTaxTreatment {
  /// Reimbursement — not in gross compensation; added back after WHT.
  NONTAXABLE_REIMBURSEMENT
  /// Non-taxable benefit (within BIR de minimis ceiling).
  DE_MINIMIS
  /// Fully taxable — included in gross taxable income.
  TAXABLE
}

// =============================================================================
// SHIFT SCHEDULES & DTR (Phase J)
// =============================================================================

/// Named shift template — defines expected start/end and work days.
model ShiftSchedule {
  id       String @id @default(cuid())
  tenantId String

  name         String
  type         ShiftType @default(FIXED)
  /// Expected time-in in 24-hour "HH:MM" format (e.g. "08:00").
  timeIn       String
  /// Expected time-out in 24-hour "HH:MM" format (e.g. "17:00").
  timeOut      String
  breakMinutes Int       @default(60)
  /// True when the shift spans midnight (e.g. night shift 22:00–06:00).
  crossesMidnight Boolean @default(false)
  /// JSON array of ISO weekday names: ["MON","TUE","WED","THU","FRI"].
  workDays     Json

  isActive  Boolean   @default(true)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant      Tenant                    @relation(fields: [tenantId], references: [id])
  assignments EmployeeShiftAssignment[]
  dtrRecords  DTRRecord[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

/// Effective-dated assignment of a ShiftSchedule to an Employee.
model EmployeeShiftAssignment {
  id              String    @id @default(cuid())
  tenantId        String
  employeeId      String
  shiftScheduleId String

  effectiveFrom DateTime
  /// Null = open-ended (current assignment).
  effectiveTo   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  employee      Employee      @relation(fields: [employeeId], references: [id])
  shiftSchedule ShiftSchedule @relation(fields: [shiftScheduleId], references: [id])

  @@index([tenantId])
  @@index([tenantId, employeeId, effectiveFrom])
}

/// One computed daily attendance record per employee per calendar date.
/// Created from AttendanceLog (kiosk/manual) or imported; computed against
/// the assigned ShiftSchedule.
model DTRRecord {
  id         String @id @default(cuid())
  tenantId   String
  employeeId String

  /// Calendar date this record covers (stored as UTC midnight).
  date            DateTime
  shiftScheduleId String?

  dayStatus        DTRDayStatus @default(PRESENT)
  workedMinutes    Int          @default(0)
  lateMinutes      Int          @default(0)
  undertimeMinutes Int          @default(0)
  /// Pre-approved overtime minutes for this day.
  otMinutes        Int          @default(0)
  /// Night-shift differential minutes (10 PM – 6 AM window).
  nsdMinutes       Int          @default(0)
  hazardMinutes    Int          @default(0)
  /// SPECIAL_HOLIDAY | REGULAR_HOLIDAY | null
  holidayType      String?

  approvalStatus DTRStatus @default(PENDING)
  approvedById   String?
  approvedAt     DateTime?
  /// Locked records cannot be edited — set by payroll finalize.
  isLocked       Boolean   @default(false)

  notes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  employee      Employee       @relation(fields: [employeeId], references: [id])
  shiftSchedule ShiftSchedule? @relation(fields: [shiftScheduleId], references: [id])

  @@unique([tenantId, employeeId, date])
  @@index([tenantId])
  @@index([tenantId, employeeId, date])
  @@index([tenantId, approvalStatus])
}

// =============================================================================
// EXPENSE CLAIMS (Phase K)
// =============================================================================

/// Employee expense reimbursement / claim record.
/// Flow: DRAFT → SUBMITTED → APPROVED (taxTreatment set) → ATTACHED (to a
/// PayrollBook) → PAID (after finalize).
model ExpenseClaim {
  id         String @id @default(cuid())
  tenantId   String
  employeeId String

  /// Free-text category (TRANSPORTATION, MEALS, ACCOMMODATION, MEDICAL, etc.).
  category        String
  description     String  @db.Text
  /// Claim amount in centavos.
  amountCents     BigInt
  /// Object store key for the attached receipt (e.g. R2 key). Nullable.
  receiptKey      String?
  /// The date the expense was incurred (UTC midnight).
  claimDate       DateTime

  status       ExpenseClaimStatus  @default(DRAFT)
  /// Set by Finance/HR during APPROVAL. Drives engine treatment.
  taxTreatment ExpenseTaxTreatment?

  approvedById    String?
  approvedAt      DateTime?
  rejectionReason String? @db.Text

  /// Set to the target PayrollBook when status = ATTACHED.
  payrollBookId String?
  /// Set to the PayrollBook that finalized (paid) this claim.
  paidInBookId  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  employee    Employee     @relation(fields: [employeeId], references: [id])
  approvedBy  User?        @relation("ExpenseClaimApprover", fields: [approvedById], references: [id])
  payrollBook PayrollBook? @relation("BookExpenseClaims", fields: [payrollBookId], references: [id])
  paidInBook  PayrollBook? @relation("BookPaidExpenseClaims", fields: [paidInBookId], references: [id])

  @@index([tenantId])
  @@index([tenantId, employeeId])
  @@index([tenantId, status])
  @@index([payrollBookId])
}

// =============================================================================
// OT APPLICATIONS (Phase R)
// =============================================================================

/// Employee files overtime for advance approval before it is paid.
/// On APPROVED the linked DTRRecord.otMinutes is set = hours × 60.
model OTApplication {
  id         String @id @default(cuid())
  tenantId   String
  employeeId String

  /// Calendar date the OT will be worked (UTC midnight).
  date          DateTime
  /// Requested OT hours (e.g. 2.5).
  hours         Decimal  @db.Decimal(5, 2)
  justification String   @db.Text

  status           ApprovalStatus @default(PENDING)
  approverId       String?
  approvedAt       DateTime?
  rejectedAt       DateTime?
  rejectionReason  String?        @db.Text
  cancelledAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId],   references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([tenantId])
  @@index([tenantId, employeeId])
  @@index([tenantId, status])
  @@index([tenantId, date])
}

// =============================================================================
// PROFILE UPDATE REQUESTS (Phase R)
// =============================================================================

/// Employee requests a change to a sensitive profile field.
/// On APPROVED the field on Employee is updated atomically.
model ProfileUpdateRequest {
  id         String @id @default(cuid())
  tenantId   String
  employeeId String

  /// Name of the Employee field being changed (e.g. "bankAccountNumber").
  field    String
  oldValue String?  @db.Text
  newValue String   @db.Text

  status          ApprovalStatus @default(PENDING)
  approverId      String?
  approvedAt      DateTime?
  rejectedAt      DateTime?
  rejectionReason String?        @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId],   references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([tenantId])
  @@index([tenantId, employeeId])
  @@index([tenantId, status])
}

// =============================================================================
// ESS SESSIONS (Phase M)
//
// Short-lived tokens for Employee Self-Service portal.  The raw 32-byte
// random token is returned to the client; only the SHA-256 hex digest is
// persisted.  Sessions last 8 hours and can be revoked explicitly (logout).
// =============================================================================

/// Employee Self-Service session.  One row per active login.
model EssSession {
  id         String    @id @default(cuid())
  tenantId   String
  employeeId String

  /// SHA-256 hex digest of the raw 32-byte token (never stored in clear text).
  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime?

  createdAt DateTime @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([tenantId])
  @@index([employeeId])
  @@index([expiresAt])
}
